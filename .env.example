# Omysha SignIn — Local Authentik Development Environment
# Copy this to .env and fill in values
# DO NOT commit .env to git
# Per UPDSS docker-guide.md: PROJECT_SERVICENAME_VARNAME convention

OMYSHA_SIGNIN_DB_PASSWORD=<generate-strong-password>
OMYSHA_SIGNIN_SECRET_KEY=<generate-with: openssl rand -hex 32>

# Port allocations (per docker-guide.md series)
# 3000 series = Web frontends (Authentik login UI + admin panel)
# 9000 series = Databases dev only (PostgreSQL, Redis)
OMYSHA_SIGNIN_SERVER_PORT=3008
OMYSHA_SIGNIN_SERVER_HTTPS_PORT=3448
OMYSHA_SIGNIN_DB_PORT=9008
OMYSHA_SIGNIN_REDIS_PORT=9018
